# ============================================================
#  Agent 服务环境变量模板
#  复制为 `.env` 后修改即可
# ============================================================

# ------- LLM 选型 -------
# 可选: deepseek | ollama | openai_compatible | rule
LLM_PROVIDER=deepseek

# ------- DeepSeek（OpenAI 兼容）-------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 可选：deepseek-chat (通用)、deepseek-reasoner (R1 推理)
DEEPSEEK_MODEL=deepseek-chat

# ------- Ollama（如果改用 ollama） -------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# ------- OpenAI 兼容 API（如 vLLM / LM Studio）-------
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=default

# ------- STT -------
# 可选: whisper | stub
STT_PROVIDER=whisper
WHISPER_MODEL_SIZE=base

# ------- RAG -------
RAG_ENABLED=true
# 启动时仅在向量库为空时自动入库；已有 .chroma 数据会跳过重复切片
RAG_AUTO_INGEST_ON_STARTUP=true

# ------- Server -------
# 开发时如需热重载可改成 true；默认关闭，避免被 Chroma 持久化文件频繁触发
SERVER_RELOAD=false

# ------- 联网检索（RAG 兜底）-------
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_TIMEOUT_SECONDS=6
WEB_SEARCH_TOP_K=3
